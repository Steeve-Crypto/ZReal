# =============================================
# ZReal Environment Configuration
# Copy this file to .env and fill in your values
# =============================================

# Django
SECRET_KEY=your-super-secret-key-here-change-in-production
DEBUG=0
ALLOWED_HOSTS=localhost,127.0.0.1,yourdomain.com

# Database (used by docker-compose)
DATABASE_URL=postgres://zreal:zreal@db:5432/zreal

# Redis
REDIS_URL=redis://redis:6379/0

# Zcash RPC Configuration
ZCASHRPC_USER=zcashrpc
ZCASHRPC_PASSWORD=your_zcash_rpc_password
ZCASHRPC_HOST=zcash          # Use 'zcash' for local container, or external IP/hostname
ZCASHRPC_PORT=18232

# Zcash TX Tool (for advanced ZSA support)
ZCASH_TX_TOOL_PATH=/app/zcash_tx_tool/target/release/zcash_tx_tool

# Stripe
STRIPE_SECRET_KEY=sk_test_your_stripe_secret_key
STRIPE_PUBLISHABLE_KEY=pk_test_your_stripe_publishable_key

# ZSA Strategy (auto, zcash_tx_tool, rich_memo, native)
ZSA_ISSUANCE_STRATEGY=auto

# Optional: Celery
CELERY_BROKER_URL=redis://redis:6379/0
CELERY_RESULT_BACKEND=redis://redis:6379/0
