# ZReal local configuration
# Copy this file to .env and fill in values as needed.

SECRET_KEY=change-me-for-production
DEBUG=1
ALLOWED_HOSTS=localhost,127.0.0.1
FRONTEND_ORIGIN=http://127.0.0.1:3000
CORS_ALLOWED_ORIGINS=http://127.0.0.1:3000,http://localhost:3000
CSRF_TRUSTED_ORIGINS=http://127.0.0.1:3000,http://localhost:3000

# Local development defaults to SQLite when DATABASE_URL is omitted.
# Docker/Postgres example:
# DATABASE_URL=postgres://zreal:zreal@db:5432/zreal

# Zcash RPC is optional for browsing/admin/document workflows, but required
# before ZReal reports ZSA tokenization as ready.
# ZCASH_RPC_URL=http://rpcuser:rpcpassword@127.0.0.1:18232
# or:
# ZCASHRPC_USER=rpcuser
# ZCASHRPC_PASSWORD=rpcpassword
# ZCASHRPC_HOST=127.0.0.1
# ZCASHRPC_PORT=18232
ZCASH_NETWORK=testnet

# Real ZSA issuance requires an external ZSA-capable tool.
# The command must print JSON containing at least operation_id, txid, or asset_id.
# Example output:
# {"status":"broadcast","operation_id":"...","txid":"...","asset_id":"..."}
ZSA_ISSUANCE_BACKEND=zcash_tx_tool
ZCASH_TX_TOOL_PATH=
ZCASH_ZSA_ISSUE_COMMAND={tool} create-zsa-issuance --from {issuer_zaddr} --asset-symbol {asset_symbol} --total-shares {total_shares} --network {network}
ZCASH_ZSA_STATUS_COMMAND={tool} status --operation-id {operation_id} --network {network}
# The command also receives safe metadata through the ZREAL_ZSA_METADATA_JSON
# environment variable. You can include {metadata_json} in the command template
# if your tool expects metadata as an argument.

# Billing is optional. Checkout fails clearly until these are configured.
STRIPE_SECRET_KEY=
STRIPE_PUBLISHABLE_KEY=
STRIPE_ISSUER_PRICE_ID=
DJSTRIPE_WEBHOOK_SECRET=
REQUIRE_ACTIVE_SUBSCRIPTION_FOR_ZSA=0

# Property data enrichment is provider-driven. Mock mode is safe for local dev and CI.
PROPERTY_DATA_PROVIDER=mock
PROPERTY_DATA_ENABLE_LIVE_CALLS=0
PROPERTY_DATA_API_KEY=
PROPERTY_DATA_REGRID_API_KEY=
PROPERTY_DATA_OPENCAGE_API_KEY=
PROPERTY_DATA_GOOGLE_API_KEY=
REGRID_API_KEY=
OPENCAGE_API_KEY=
GOOGLE_GEOCODING_API_KEY=

# Optional async workers
REDIS_URL=redis://redis:6379/0
CELERY_BROKER_URL=redis://redis:6379/0
CELERY_RESULT_BACKEND=redis://redis:6379/0
